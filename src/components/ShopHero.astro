---
/**
 * ShopHero — shop landing page hero section.
 *
 * AI component schema: see api/src/component-docs/shop-hero.md
 */
interface Props {
  heading: string;
  subheading?: string;
  ctaLabel?: string;
  ctaHref?: string;
  secondaryLabel?: string;
  secondaryHref?: string;
  imageUrl?: string;
  imageAlt?: string;
  badge?: string;
}

const {
  heading,
  subheading,
  ctaLabel = 'Se alle produkter',
  ctaHref = '/shop/',
  secondaryLabel,
  secondaryHref,
  imageUrl,
  imageAlt = '',
  badge,
} = Astro.props;
---

<section class="shop-hero relative overflow-hidden bg-[var(--color-bg-subtle,var(--color-neutral-100))]">
  <div class="mx-auto max-w-[var(--container-max-width)] px-[var(--container-padding-x)]
              py-16 md:py-24 flex flex-col md:flex-row items-center gap-12">

    <!-- Text content -->
    <div class="flex-1 text-center md:text-left" data-reveal>
      {badge && (
        <span class="inline-block mb-4 rounded-full border border-[var(--color-primary)] px-4 py-1
                     text-sm font-medium text-[var(--color-primary)]">
          {badge}
        </span>
      )}
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold leading-tight text-[var(--color-text-primary)]">
        {heading}
      </h1>
      {subheading && (
        <p class="mt-4 text-lg md:text-xl text-[var(--color-text-secondary)] max-w-lg mx-auto md:mx-0">
          {subheading}
        </p>
      )}
      <div class="mt-8 flex flex-wrap gap-4 justify-center md:justify-start">
        <a
          href={ctaHref}
          class="focus-modern inline-flex min-h-[48px] items-center rounded-[var(--radius-full)]
                 btn-gradient px-6 py-3 text-base font-semibold text-[var(--color-text-on-primary)]
                 shadow-[var(--shadow-sm)] transition-opacity hover:opacity-90"
        >
          {ctaLabel}
        </a>
        {secondaryLabel && secondaryHref && (
          <a
            href={secondaryHref}
            class="focus-modern inline-flex min-h-[48px] items-center rounded-[var(--radius-full)]
                   border border-[var(--color-border)] bg-[var(--color-bg-page)]
                   px-6 py-3 text-base font-semibold text-[var(--color-text-primary)]
                   transition-colors hover:bg-[var(--color-neutral-100)]"
          >
            {secondaryLabel}
          </a>
        )}
      </div>
    </div>

    <!-- Image -->
    {imageUrl && (
      <div class="flex-1 w-full max-w-lg" data-reveal>
        <img
          src={imageUrl}
          alt={imageAlt}
          width="600"
          height="500"
          loading="eager"
          decoding="async"
          class="w-full h-auto rounded-[var(--radius-xl,var(--radius-lg))] shadow-[var(--shadow-lg)]
                 object-cover aspect-[6/5]"
        />
      </div>
    )}
  </div>
</section>
