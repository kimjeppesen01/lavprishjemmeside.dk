---
// src/themes/portfolio/layout/Nav.astro
import headerFooter from '../../../data/header-footer.json';

const logoUrl = headerFooter.header_logo_url || '/favicon.svg';
const logoText = headerFooter.header_logo_text || 'Studio';
const navLinks = Array.isArray(headerFooter.header_menu_1) ? headerFooter.header_menu_1 : [];
const ctaLinks = Array.isArray(headerFooter.header_menu_2) ? headerFooter.header_menu_2 : [];
---
<header id="main-header" class="fixed top-0 left-0 right-0 z-40 flex items-center justify-between px-8 h-20 mix-blend-normal">
  <a href="/" class="flex items-center gap-3 group">
    <img src={logoUrl} alt={logoText} class="h-8 w-8 object-contain" width="32" height="32" />
    <span class="font-bold text-base tracking-tight" style="font-family: var(--font-heading); color: var(--color-text-primary)">{logoText}</span>
  </a>
  <nav class="hidden md:flex items-center gap-8">
    {navLinks.map((link: { href: string; label: string }) => (
      <a href={link.href} class="text-sm text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)] transition-colors">{link.label}</a>
    ))}
    {ctaLinks.map((link: { href: string; label: string }) => (
      <a href={link.href} class="text-sm font-semibold text-[var(--color-accent)] hover:text-[var(--color-accent-hover)] transition-colors">{link.label}</a>
    ))}
  </nav>
</header>
<div class="h-20"></div>
