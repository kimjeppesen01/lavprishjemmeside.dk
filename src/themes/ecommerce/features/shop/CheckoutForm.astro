---
// src/themes/ecommerce/features/shop/CheckoutForm.astro
// Checkout form wired to the existing Flatpay/shop API.
interface Props {
  currency?: string;
}
const { currency = 'DKK' } = Astro.props;
---
<div class="max-w-2xl mx-auto">
  <form id="ec-checkout-form" class="space-y-6">
    <div>
      <h2 class="text-xl font-bold text-[var(--color-text-primary)] mb-4">Leveringsoplysninger</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium text-[var(--color-text-primary)] mb-1">Fornavn</label>
          <input type="text" name="first_name" required class="w-full border border-[var(--color-border)] rounded-[var(--radius-md)] px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-[var(--color-primary)]" />
        </div>
        <div>
          <label class="block text-sm font-medium text-[var(--color-text-primary)] mb-1">Efternavn</label>
          <input type="text" name="last_name" required class="w-full border border-[var(--color-border)] rounded-[var(--radius-md)] px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-[var(--color-primary)]" />
        </div>
        <div class="md:col-span-2">
          <label class="block text-sm font-medium text-[var(--color-text-primary)] mb-1">E-mail</label>
          <input type="email" name="email" required class="w-full border border-[var(--color-border)] rounded-[var(--radius-md)] px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-[var(--color-primary)]" />
        </div>
        <div class="md:col-span-2">
          <label class="block text-sm font-medium text-[var(--color-text-primary)] mb-1">Adresse</label>
          <input type="text" name="address" required class="w-full border border-[var(--color-border)] rounded-[var(--radius-md)] px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-[var(--color-primary)]" />
        </div>
        <div>
          <label class="block text-sm font-medium text-[var(--color-text-primary)] mb-1">Postnummer</label>
          <input type="text" name="zip" required class="w-full border border-[var(--color-border)] rounded-[var(--radius-md)] px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-[var(--color-primary)]" />
        </div>
        <div>
          <label class="block text-sm font-medium text-[var(--color-text-primary)] mb-1">By</label>
          <input type="text" name="city" required class="w-full border border-[var(--color-border)] rounded-[var(--radius-md)] px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-[var(--color-primary)]" />
        </div>
      </div>
    </div>

    <div id="ec-order-summary" class="bg-[var(--color-bg-section-alt)] rounded-[var(--radius-md)] p-4">
      <p class="text-sm font-semibold text-[var(--color-text-primary)] mb-3">Ordreoversigt</p>
      <div id="ec-summary-items" class="space-y-2 text-sm text-[var(--color-text-secondary)] mb-3"></div>
      <div class="flex justify-between font-semibold text-[var(--color-text-primary)] border-t border-[var(--color-border)] pt-3">
        <span>Total</span>
        <span id="ec-summary-total">0 {currency}</span>
      </div>
    </div>

    <div id="ec-checkout-error" class="hidden text-sm text-red-600 bg-red-50 rounded-[var(--radius-md)] p-3"></div>

    <button type="submit" class="w-full py-4 bg-[var(--color-primary)] text-white font-bold rounded-[var(--radius-card)] hover:bg-[var(--color-primary-hover)] transition-colors">
      Gå til betaling
    </button>
  </form>
</div>

<script>
  async function loadSummary() {
    try {
      const res = await fetch('/api/cart');
      const data = await res.json();
      const items: Array<{ name: string; quantity: number; price: number; currency?: string }> = data.items || [];
      const summaryEl = document.getElementById('ec-summary-items');
      const totalEl = document.getElementById('ec-summary-total');
      if (summaryEl) {
        summaryEl.innerHTML = items.map(i =>
          `<div class="flex justify-between"><span>${i.name} x${i.quantity}</span><span>${(i.price * i.quantity).toLocaleString('da-DK')} ${i.currency || 'DKK'}</span></div>`
        ).join('');
      }
      const total = items.reduce((s, i) => s + i.price * i.quantity, 0);
      if (totalEl) totalEl.textContent = `${total.toLocaleString('da-DK')} DKK`;
    } catch {}
  }

  document.getElementById('ec-checkout-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const form = e.target as HTMLFormElement;
    const data = Object.fromEntries(new FormData(form));
    const errEl = document.getElementById('ec-checkout-error');
    try {
      const res = await fetch('/api/checkout/initiate', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });
      const result = await res.json();
      if (result.redirect_url) {
        window.location.href = result.redirect_url;
      } else if (result.payment_url) {
        window.location.href = result.payment_url;
      } else {
        throw new Error(result.message || 'Betalingsinitieringen fejlede');
      }
    } catch (err) {
      if (errEl) {
        errEl.textContent = err instanceof Error ? err.message : 'Noget gik galt. Prøv igen.';
        errEl.classList.remove('hidden');
      }
    }
  });

  loadSummary();
</script>
