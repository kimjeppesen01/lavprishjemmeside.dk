---
// src/themes/ecommerce/features/shop/ProductGrid.astro
interface Product {
  id: string | number;
  name: string;
  price: number;
  compare_price?: number;
  image_url?: string;
  slug?: string;
  currency?: string;
}
interface Props {
  products?: Product[];
  currency?: string;
  title?: string;
}
const { products = [], currency = 'DKK', title } = Astro.props;
---
<section class="py-[var(--section-padding-y)]">
  <div class="mx-auto px-[var(--container-padding-x)]" style="max-width: var(--container-max-width)">
    {title && <h2 class="text-2xl md:text-3xl font-bold text-[var(--color-text-primary)] mb-8">{title}</h2>}
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-5">
      {products.map(p => (
        <a href={`/shop/${p.slug || p.id}`} class="group block rounded-[var(--radius-card)] border border-[var(--color-border)] overflow-hidden hover:shadow-[var(--shadow-md)] transition-shadow">
          {p.image_url
            ? <img src={p.image_url} alt={p.name} class="w-full h-48 object-cover group-hover:scale-105 transition-transform duration-300" width="300" height="192" />
            : <div class="w-full h-48 bg-[var(--color-bg-section-alt)] flex items-center justify-center text-[var(--color-neutral-300)]">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
              </div>
          }
          <div class="p-4">
            <p class="text-sm font-medium text-[var(--color-text-primary)] truncate mb-1">{p.name}</p>
            <div class="flex items-center gap-2">
              <span class="text-sm font-bold text-[var(--color-primary)]">{p.price.toLocaleString('da-DK')} {p.currency || currency}</span>
              {p.compare_price && p.compare_price > p.price && (
                <span class="text-xs text-[var(--color-neutral-600)] line-through">{p.compare_price.toLocaleString('da-DK')}</span>
              )}
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
