---
// src/themes/restaurant/sections/cta-section.astro
interface Props { title?: string; body?: string; cta_label?: string; cta_href?: string; }
const { title, body, cta_label = 'Bestil nu', cta_href = '/bestil' } = Astro.props;
---
<section class="py-[var(--section-padding-y)] bg-[var(--color-accent-light)]">
  <div class="mx-auto px-[var(--container-padding-x)] text-center" style="max-width: var(--container-max-width)">
    {title && <h2 class="text-3xl md:text-5xl font-bold text-[var(--color-primary)] mb-4" style="font-family: var(--font-heading)">{title}</h2>}
    {body && <p class="text-lg text-[var(--color-text-secondary)] mb-8 max-w-2xl mx-auto">{body}</p>}
    <a href={cta_href} class="inline-flex px-10 py-4 bg-[var(--color-primary)] text-[var(--color-text-on-primary)] font-bold rounded-[var(--radius-card)] hover:bg-[var(--color-primary-hover)] transition-colors">
      {cta_label}
    </a>
  </div>
</section>
