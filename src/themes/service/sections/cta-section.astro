---
// src/themes/service/sections/cta-section.astro
interface Props { title?: string; body?: string; cta_label?: string; cta_href?: string; }
const { title, body, cta_label = 'Book tid', cta_href = '/book' } = Astro.props;
---
<section class="py-[var(--section-padding-y)] bg-[var(--color-primary)]">
  <div class="mx-auto px-[var(--container-padding-x)] text-center" style="max-width: var(--container-max-width)">
    {title && <h2 class="text-3xl md:text-4xl font-bold text-white mb-4" style="font-family: var(--font-heading)">{title}</h2>}
    {body && <p class="text-lg text-white/80 mb-8 max-w-2xl mx-auto">{body}</p>}
    <a href={cta_href} class="inline-flex px-10 py-4 bg-white text-[var(--color-primary)] font-bold rounded-[var(--radius-full)] hover:bg-[var(--color-primary-light)] transition-colors">
      {cta_label}
    </a>
  </div>
</section>
