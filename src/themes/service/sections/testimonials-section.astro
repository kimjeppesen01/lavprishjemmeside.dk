---
// src/themes/service/sections/testimonials-section.astro
interface Testimonial { quote?: string; author?: string; role?: string; avatar_url?: string; rating?: number; }
interface Props { title?: string; items?: Testimonial[]; }
const { title, items = [] } = Astro.props;
---
<section class="py-[var(--section-padding-y)] bg-[var(--color-bg-section-alt)]">
  <div class="mx-auto px-[var(--container-padding-x)]" style="max-width: var(--container-max-width)">
    {title && <h2 class="text-3xl md:text-4xl font-bold text-[var(--color-text-primary)] text-center mb-12" style="font-family: var(--font-heading)">{title}</h2>}
    {items.length > 0 && (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {items.map((t) => (
          <blockquote class="bg-white rounded-[var(--radius-card)] p-7 shadow-[var(--shadow-sm)] border border-[var(--color-border)]">
            {t.rating && (
              <div class="flex gap-1 mb-4">
                {Array.from({ length: 5 }).map((_, i) => (
                  <svg xmlns="http://www.w3.org/2000/svg" class={`h-4 w-4 ${i < (t.rating || 0) ? 'text-[var(--color-accent)]' : 'text-[var(--color-neutral-300)]'}`} viewBox="0 0 20 20" fill="currentColor">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                  </svg>
                ))}
              </div>
            )}
            {t.quote && <p class="text-[var(--color-text-secondary)] mb-6 leading-relaxed">"{t.quote}"</p>}
            <footer class="flex items-center gap-3">
              {t.avatar_url && <img src={t.avatar_url} alt={t.author || ''} class="w-10 h-10 rounded-full object-cover" width="40" height="40" />}
              <div>
                {t.author && <p class="font-semibold text-sm text-[var(--color-text-primary)]">{t.author}</p>}
                {t.role && <p class="text-xs text-[var(--color-text-secondary)]">{t.role}</p>}
              </div>
            </footer>
          </blockquote>
        ))}
      </div>
    )}
  </div>
</section>
