---
// src/themes/service/sections/hero-section.astro
interface Props {
  title?: string;
  subtitle?: string;
  body?: string;
  cta_label?: string;
  cta_href?: string;
  image_url?: string;
  image_alt?: string;
}
const { title, subtitle, body, cta_label = 'Book tid', cta_href = '/book', image_url, image_alt = '' } = Astro.props;
---
<section class="py-20 md:py-28 bg-[var(--color-bg-warm)]">
  <div class="mx-auto px-[var(--container-padding-x)] flex flex-col md:flex-row items-center gap-12" style="max-width: var(--container-max-width)">
    <div class="flex-1 text-center md:text-left">
      {subtitle && <p class="text-sm font-semibold uppercase tracking-widest text-[var(--color-accent)] mb-3">{subtitle}</p>}
      {title && <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-[var(--color-text-primary)] leading-tight mb-4" style="font-family: var(--font-heading)">{title}</h1>}
      {body && <p class="text-lg text-[var(--color-text-secondary)] mb-8 max-w-lg">{body}</p>}
      <a href={cta_href} class="inline-flex items-center gap-2 px-8 py-3 rounded-[var(--radius-full)] bg-[var(--color-primary)] text-white font-semibold hover:bg-[var(--color-primary-hover)] transition-colors shadow-[var(--shadow-md)]">
        {cta_label}
      </a>
    </div>
    {image_url && (
      <div class="flex-1 flex justify-center">
        <img src={image_url} alt={image_alt} class="rounded-[var(--radius-2xl)] shadow-[var(--shadow-lg)] max-w-sm md:max-w-md w-full object-cover" width="480" height="560" />
      </div>
    )}
  </div>
</section>
