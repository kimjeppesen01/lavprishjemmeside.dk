---
// src/themes/service/layout/Footer.astro
import headerFooter from '../../../data/header-footer.json';

const siteName = headerFooter.footer_site_name || 'Service';
const navLinks = Array.isArray(headerFooter.footer_menu_1) ? headerFooter.footer_menu_1 : [];
const email = headerFooter.footer_email || '';
const phone = headerFooter.footer_phone || '';
---
<footer class="bg-[var(--color-bg-warm)] border-t border-[var(--color-border)] py-12">
  <div class="mx-auto px-[var(--container-padding-x)]" style="max-width: var(--container-max-width)">
    <div class="flex flex-col md:flex-row justify-between gap-8 mb-8">
      <div>
        <p class="font-semibold text-lg text-[var(--color-text-primary)] mb-2" style="font-family: var(--font-heading)">{siteName}</p>
        {phone && <p class="text-sm text-[var(--color-text-secondary)] mb-1"><a href={`tel:${phone}`} class="hover:text-[var(--color-primary)] transition-colors">{phone}</a></p>}
        {email && <p class="text-sm text-[var(--color-text-secondary)]"><a href={`mailto:${email}`} class="hover:text-[var(--color-primary)] transition-colors">{email}</a></p>}
      </div>
      {navLinks.length > 0 && (
        <nav class="flex flex-wrap gap-5">
          {navLinks.map((link: { href: string; label: string }) => (
            <a href={link.href} class="text-sm text-[var(--color-text-secondary)] hover:text-[var(--color-primary)] transition-colors">{link.label}</a>
          ))}
        </nav>
      )}
    </div>
    <p class="text-xs text-[var(--color-neutral-600)]">&copy; {new Date().getFullYear()} {siteName}</p>
  </div>
</footer>
