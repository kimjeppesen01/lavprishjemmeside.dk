---
import AdminLayout from '../../layouts/AdminLayout.astro';
const apiUrl = import.meta.env.PUBLIC_API_URL || 'https://api.lavprishjemmeside.dk';
---

<AdminLayout title="Oversigt">
  <div id="master-required-banner" class="hidden mb-4 rounded-lg bg-amber-50 border border-amber-200 px-4 py-3 text-sm text-amber-800" role="alert">
    Kun master-brugere har adgang til Master Hub.
  </div>
  <script is:inline>
    (function() {
      if (typeof window !== 'undefined' && window.location.search.indexOf('message=master_required') !== -1) {
        var el = document.getElementById('master-required-banner');
        if (el) el.classList.remove('hidden');
      }
    })();
  </script>
  <!-- Loading state -->
  <div id="loading" class="text-center py-12 text-gray-500">Henter data...</div>

  <!-- Error state -->
  <div id="error" class="hidden text-center py-12">
    <p class="text-red-600 mb-4" id="error-text"></p>
    <button onclick="window.location.reload()" class="text-blue-600 underline">Prøv igen</button>
  </div>

  <!-- Dashboard content (hidden until data loads) -->
  <div id="dashboard" class="hidden">
    <div class="flex flex-wrap items-center justify-between gap-4 mb-6">
      <div class="space-y-1">
        <h1 class="text-2xl font-bold">Oversigt</h1>
        <p class="text-sm text-gray-500">Brug build-id'et nedenfor når en klient skal opdateres eller supporteres.</p>
      </div>
      <button id="dashboard-publish-btn" class="px-4 py-2 bg-amber-600 hover:bg-amber-700 text-white font-medium rounded-lg text-sm">
        Publicer til live (~90 sek)
      </button>
    </div>

    <div id="rollout-banner" class="hidden mb-6 rounded-2xl border px-4 py-4 text-sm"></div>

    <div class="mb-8 rounded-2xl bg-slate-900 text-white shadow-lg">
      <div class="flex flex-wrap items-start justify-between gap-4 p-5">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.24em] text-slate-300">CMS-version</p>
          <div class="mt-2 flex flex-wrap items-center gap-3">
            <p id="cms-build" class="text-2xl font-semibold">—</p>
            <span id="cms-release-pill" class="rounded-full bg-white/10 px-3 py-1 text-xs font-medium text-slate-200">Release —</span>
          </div>
          <p id="cms-version-help" class="mt-2 text-sm text-slate-300">Hent versionsdata fra API...</p>
        </div>
        <button id="cms-copy-version-btn" class="rounded-lg border border-white/15 bg-white/10 px-4 py-2 text-sm font-medium text-white transition hover:bg-white/15">
          Kopiér build-id
        </button>
      </div>
      <div class="grid grid-cols-1 gap-4 border-t border-white/10 px-5 py-4 text-sm text-slate-200 md:grid-cols-3">
        <div>
          <p class="text-xs uppercase tracking-[0.2em] text-slate-400">Commit</p>
          <p id="cms-commit" class="mt-1 font-mono text-sm text-white">—</p>
        </div>
        <div>
          <p class="text-xs uppercase tracking-[0.2em] text-slate-400">Seneste kodeændring</p>
          <p id="cms-committed-at" class="mt-1 text-white">—</p>
        </div>
        <div>
          <p class="text-xs uppercase tracking-[0.2em] text-slate-400">Opdateringskanal</p>
          <p id="cms-update-channel" class="mt-1 text-white">—</p>
        </div>
      </div>
    </div>

    <!-- Settings overview: Pages + Global + Media & SEO -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-8">
      <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-5">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-lg font-semibold text-gray-900">Sider</h2>
          <a href="/admin/pages/" class="text-sm text-blue-600 hover:underline">Rediger →</a>
        </div>
        <div id="settings-pages" class="space-y-2 text-sm">
          <p class="text-gray-500">Henter...</p>
        </div>
      </div>
      <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-5">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-lg font-semibold text-gray-900">Globale indstillinger</h2>
          <div class="flex gap-3">
            <a href="/admin/styling/" class="text-sm text-blue-600 hover:underline">Design →</a>
            <a href="/admin/header-footer/" class="text-sm text-blue-600 hover:underline">Header →</a>
          </div>
        </div>
        <div id="settings-global" class="space-y-2 text-sm">
          <p class="text-gray-500">Henter...</p>
        </div>
      </div>
      <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-5">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-lg font-semibold text-gray-900">Indhold & SEO</h2>
        </div>
        <div class="space-y-3 text-sm">
          <a href="/admin/media/" class="flex items-center gap-2 text-blue-600 hover:underline">
            <span>🖼</span> Mediebibliotek
          </a>
          <a href="/admin/pages/" class="flex items-center gap-2 text-blue-600 hover:underline">
            <span>🔍</span> SEO for sider
          </a>
          <a href="/admin/ai-assemble/" class="flex items-center gap-2 text-blue-600 hover:underline">
            <span>⚡</span> AI Indholdsudvikler
          </a>
        </div>
      </div>
    </div>

    <!-- Metric cards -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
      <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-5">
        <p class="text-sm text-gray-500 mb-1">Hændelser i alt</p>
        <p class="text-3xl font-bold" id="stat-events-total">&mdash;</p>
      </div>
      <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-5">
        <p class="text-sm text-gray-500 mb-1">Hændelser i dag</p>
        <p class="text-3xl font-bold" id="stat-events-today">&mdash;</p>
      </div>
      <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-5">
        <p class="text-sm text-gray-500 mb-1">Sessioner i alt</p>
        <p class="text-3xl font-bold" id="stat-sessions-total">&mdash;</p>
      </div>
      <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-5">
        <p class="text-sm text-gray-500 mb-1">Gns. sider pr. session</p>
        <p class="text-3xl font-bold" id="stat-avg-pages">&mdash;</p>
      </div>
    </div>

    <!-- Two-column: Top Events + Top Landing Pages -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-8">
      <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-5">
        <h2 class="text-lg font-semibold mb-4">Top hændelser</h2>
        <table class="w-full text-sm">
          <thead>
            <tr class="text-left text-gray-500 border-b">
              <th class="pb-2">Hændelse</th>
              <th class="pb-2">Type</th>
              <th class="pb-2 text-right">Antal</th>
            </tr>
          </thead>
          <tbody id="table-top-events"></tbody>
        </table>
      </div>

      <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-5">
        <h2 class="text-lg font-semibold mb-4">Top landingssider</h2>
        <table class="w-full text-sm">
          <thead>
            <tr class="text-left text-gray-500 border-b">
              <th class="pb-2">Side</th>
              <th class="pb-2 text-right">Sessioner</th>
            </tr>
          </thead>
          <tbody id="table-top-pages"></tbody>
        </table>
      </div>
    </div>

    <!-- Recent events -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-5">
      <h2 class="text-lg font-semibold mb-4">Seneste hændelser</h2>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="text-left text-gray-500 border-b">
              <th class="pb-2">Type</th>
              <th class="pb-2">Navn</th>
              <th class="pb-2">Side</th>
              <th class="pb-2">Tidspunkt</th>
            </tr>
          </thead>
          <tbody id="table-recent-events"></tbody>
        </table>
      </div>
    </div>
  </div>

  <script define:vars={{ apiUrl }}>
  (function() {
    var API = apiUrl;
    var token = localStorage.getItem('admin_token');
    if (!token) return;

    function authFetch(url) {
      return fetch(url, {
        headers: { 'Authorization': 'Bearer ' + token }
      }).then(function(res) {
        if (res.status === 401 || res.status === 403) {
          localStorage.removeItem('admin_token');
          window.location.href = '/admin/';
          throw new Error('Unauthorized');
        }
        if (res.status === 503) {
          throw new Error('503 Service Unavailable — API-serveren er utilgængelig. Genstart Node.js på serveren (touch api/tmp/restart.txt).');
        }
        if (!res.ok) {
          throw new Error('HTTP ' + res.status + ' — ' + res.statusText);
        }
        return res.json();
      });
    }

    function esc(str) {
      var div = document.createElement('div');
      div.textContent = str || '';
      return div.innerHTML;
    }

    function fmt(dateStr) {
      if (!dateStr) return '\u2014';
      var d = new Date(dateStr);
      return d.toLocaleDateString('da-DK') + ' ' + d.toLocaleTimeString('da-DK', { hour: '2-digit', minute: '2-digit' });
    }

    function setVersionMeta(meta) {
      var build = meta && meta.build ? meta.build : '\u2014';
      var releaseVersion = meta && meta.release_version ? meta.release_version : '\u2014';
      var commitShort = meta && meta.commit_short ? meta.commit_short : '\u2014';
      var committedAt = meta && meta.git_committed_at ? fmt(meta.git_committed_at) : '\u2014';
      var updateChannel = meta && meta.update_channel ? meta.update_channel : '\u2014';
      var gitRef = meta && meta.git_ref ? meta.git_ref : null;
      var dirty = Boolean(meta && meta.dirty);
      var helpText = 'Del dette build-id når en klient skal opdateres.';

      if (gitRef && gitRef !== build) {
        helpText += ' Git reference: ' + gitRef + '.';
      }
      if (dirty) {
        helpText += ' Denne installation har lokale ændringer og er ikke på en ren commit.';
      }

      document.getElementById('cms-build').textContent = build;
      document.getElementById('cms-release-pill').textContent = 'Release ' + releaseVersion;
      document.getElementById('cms-version-help').textContent = helpText;
      document.getElementById('cms-commit').textContent = commitShort;
      document.getElementById('cms-committed-at').textContent = committedAt;
      document.getElementById('cms-update-channel').textContent = updateChannel;

      var copyBtn = document.getElementById('cms-copy-version-btn');
      if (copyBtn) {
        copyBtn.dataset.copyValue = build;
      }
    }

    function renderRolloutStatus(payload) {
      var banner = document.getElementById('rollout-banner');
      if (!banner) return;

      if (!payload) {
        banner.className = 'mb-6 rounded-2xl border border-amber-200 bg-amber-50 px-4 py-4 text-sm text-amber-800';
        banner.innerHTML = '<strong>Opdateringsstatus utilgængelig.</strong> Kunne ikke hente release-status fra Agent Enterprise.';
        return;
      }

      var comparison = payload.comparison || payload.sourceVsParent || null;
      var summary = payload.summary || null;
      var status = comparison && comparison.status ? comparison.status : (payload.status || summary && summary.status) || 'unknown';
      var message = comparison && comparison.message
        ? comparison.message
        : (payload.error || (summary && summary.warnings && summary.warnings[0]) || 'Ingen aktiv release-advarsel.');

      if (status === 'aligned' && !(summary && summary.pendingParentRollout) && !(summary && summary.clientUpdateCount)) {
        banner.classList.add('hidden');
        banner.innerHTML = '';
        return;
      }

      if (status === 'changelog_live_pending' || (summary && summary.pendingParentRollout)) {
        banner.className = 'mb-6 rounded-2xl border border-amber-200 bg-amber-50 px-4 py-4 text-sm text-amber-900';
        banner.innerHTML = '<strong>Rollout afventer.</strong> ' + message;
        return;
      }

      if (status === 'update_available') {
        banner.className = 'mb-6 rounded-2xl border border-blue-200 bg-blue-50 px-4 py-4 text-sm text-blue-900';
        banner.innerHTML = '<strong>Opdatering tilgængelig.</strong> ' + message;
        return;
      }

      banner.className = 'mb-6 rounded-2xl border border-amber-200 bg-amber-50 px-4 py-4 text-sm text-amber-800';
      banner.innerHTML = '<strong>Opdateringsstatus utilgængelig.</strong> ' + message;
    }

    function refreshRolloutStatus() {
      authFetch(API + '/rollout/status')
        .then(function(payload) {
          renderRolloutStatus(payload);
        })
        .catch(function() {
          renderRolloutStatus(null);
        });
    }

    Promise.all([
      authFetch(API + '/health').catch(function() { return null; }),
      authFetch(API + '/rollout/status').catch(function() { return null; }),
      authFetch(API + '/events/summary').catch(function() {
        return { total: 0, today: 0, top_events: [], recent: [] };
      }),
      authFetch(API + '/sessions/summary').catch(function() {
        return { total: 0, today: 0, avg_pages: 0, top_pages: [], recent: [] };
      }),
      authFetch(API + '/design-settings/').catch(function() { return null; }),
      authFetch(API + '/page-components?page=all').catch(function() { return []; })
    ])
    .then(function(results) {
      var health = results[0] || null;
      var rollout = results[1] || null;
      var events = results[2] || { total: 0, today: 0, top_events: [], recent: [] };
      var sessions = results[3] || { total: 0, today: 0, avg_pages: 0, top_pages: [], recent: [] };
      var designSettings = results[4];
      var pageComponents = results[5] || [];

      setVersionMeta(health && health.cms ? health.cms : null);
      renderRolloutStatus(rollout);

      // Settings: Pages (group by page_path)
      var pageGroups = {};
      pageComponents.forEach(function(pc) {
        var path = (pc.page_path || '/').trim();
        if (!pageGroups[path]) pageGroups[path] = { total: 0, published: 0 };
        pageGroups[path].total++;
        if (pc.is_published) pageGroups[path].published++;
      });
      var pagesHtml = '';
      var paths = Object.keys(pageGroups).sort();
      if (paths.length === 0) {
        pagesHtml = '<p class="text-gray-500">Ingen sider endnu. <a href="/admin/ai-assemble/" class="text-blue-600 hover:underline">Opret side</a></p>';
      } else {
        paths.forEach(function(path) {
          var g = pageGroups[path];
          var pub = g.published === g.total ? '<span class="text-green-600">●</span>' : '<span class="text-amber-500">○</span>';
          pagesHtml += '<div class="flex justify-between py-1 border-b border-gray-100 last:border-0">'
            + '<span class="font-mono text-xs">' + esc(path) + '</span>'
            + '<span>' + pub + ' ' + g.published + '/' + g.total + ' komp.</span></div>';
        });
      }
      document.getElementById('settings-pages').innerHTML = pagesHtml;

      // Settings: Global (design) + feature toggles
      var globalHtml = '';
      if (designSettings) {
        globalHtml = '<div class="flex items-center gap-2 py-1"><span class="w-4 h-4 rounded border border-gray-300" style="background:' + esc(designSettings.color_primary || '#2563EB') + '"></span><span>Primær: ' + esc(designSettings.color_primary || '—') + '</span></div>'
          + '<div class="py-1">Font: ' + esc(designSettings.font_heading || designSettings.font_body || '—') + '</div>'
          + '<div class="py-1">Kantradius: ' + esc(designSettings.border_radius || '—') + '</div>'
          + '<div class="py-1">Skygge: ' + esc(designSettings.shadow_style || '—') + '</div>'
          + '<div class="pt-2 mt-2 border-t border-gray-100 space-y-1"><span class="text-xs text-gray-500 uppercase tracking-wider">Funktioner</span>'
          + '<div class="py-1">' + ((designSettings.feature_smooth_scroll ?? 1) !== 0 ? '<span class="text-green-600">●</span>' : '<span class="text-gray-400">○</span>') + ' Smooth scroll</div>'
          + '<div class="py-1">' + ((designSettings.feature_grain_overlay ?? 1) !== 0 ? '<span class="text-green-600">●</span>' : '<span class="text-gray-400">○</span>') + ' Korn-overlay</div>'
          + '<div class="py-1">' + ((designSettings.feature_page_loader ?? 1) !== 0 ? '<span class="text-green-600">●</span>' : '<span class="text-gray-400">○</span>') + ' Sideloader</div>'
          + '<div class="py-1">' + ((designSettings.feature_sticky_header ?? 1) !== 0 ? '<span class="text-green-600">●</span>' : '<span class="text-gray-400">○</span>') + ' Klæbende header</div></div>';
      } else {
        globalHtml = '<p class="text-gray-500">Kunne ikke hente. <a href="/admin/styling/" class="text-blue-600 hover:underline">Åbn styling</a></p>';
      }
      document.getElementById('settings-global').innerHTML = globalHtml;

      // Metric cards
      document.getElementById('stat-events-total').textContent = (events.total || 0).toLocaleString('da-DK');
      document.getElementById('stat-events-today').textContent = (events.today || 0).toLocaleString('da-DK');
      document.getElementById('stat-sessions-total').textContent = (sessions.total || 0).toLocaleString('da-DK');
      document.getElementById('stat-avg-pages').textContent = sessions.avg_pages != null ? sessions.avg_pages : '—';

      // Top events
      var html = '';
      (events.top_events || []).forEach(function(ev) {
        html += '<tr class="border-b border-gray-100">'
          + '<td class="py-2">' + esc(ev.event_name) + '</td>'
          + '<td class="py-2"><span class="inline-block px-2 py-0.5 rounded text-xs bg-gray-100">' + esc(ev.event_type) + '</span></td>'
          + '<td class="py-2 text-right font-medium">' + ev.count + '</td>'
          + '</tr>';
      });
      document.getElementById('table-top-events').innerHTML = html;

      // Top landing pages
      html = '';
      (sessions.top_pages || []).forEach(function(p) {
        html += '<tr class="border-b border-gray-100">'
          + '<td class="py-2 font-mono text-xs">' + esc(p.first_page) + '</td>'
          + '<td class="py-2 text-right font-medium">' + p.count + '</td>'
          + '</tr>';
      });
      document.getElementById('table-top-pages').innerHTML = html;

      // Recent events
      html = '';
      (events.recent || []).forEach(function(ev) {
        html += '<tr class="border-b border-gray-100">'
          + '<td class="py-2"><span class="inline-block px-2 py-0.5 rounded text-xs bg-gray-100">' + esc(ev.event_type) + '</span></td>'
          + '<td class="py-2">' + esc(ev.event_name) + '</td>'
          + '<td class="py-2 font-mono text-xs">' + esc(ev.page_url) + '</td>'
          + '<td class="py-2 text-gray-500 text-xs whitespace-nowrap">' + fmt(ev.created_at) + '</td>'
          + '</tr>';
      });
      document.getElementById('table-recent-events').innerHTML = html;

      // Show dashboard
      document.getElementById('loading').classList.add('hidden');
      document.getElementById('dashboard').classList.remove('hidden');
      window.setInterval(refreshRolloutStatus, 60000);
    })
    .catch(function(err) {
      if (err.message === 'Unauthorized') return;
      document.getElementById('loading').classList.add('hidden');
      var msg = err.message === 'Failed to fetch'
        ? ('Kunne ikke forbinde til API (' + API + '). Tjek om serveren kører.')
        : (err.message.indexOf('503') >= 0 ? err.message : 'Kunne ikke hente data: ' + err.message);
      document.getElementById('error-text').textContent = msg;
      document.getElementById('error').classList.remove('hidden');
    });

    document.getElementById('dashboard-publish-btn')?.addEventListener('click', function() {
      var btn = this;
      btn.disabled = true;
      btn.textContent = 'Starter...';
      fetch(API + '/publish', {
        method: 'POST',
        headers: { 'Authorization': 'Bearer ' + token, 'Content-Type': 'application/json' }
      }).then(function(res) { return res.json().then(function(d) { return { ok: res.ok, data: d }; }); })
        .then(function(r) {
          if (r.ok) {
            btn.textContent = '✓ Udrulning startet';
            btn.classList.remove('bg-amber-600', 'hover:bg-amber-700');
            btn.classList.add('bg-green-600');
          } else {
            throw new Error(r.data.error || 'Fejl');
          }
        })
        .catch(function(err) {
          alert('Fejl: ' + err.message);
          btn.textContent = 'Publicer til live (~90 sek)';
        })
        .finally(function() {
          btn.disabled = false;
        });
    });

    document.getElementById('cms-copy-version-btn')?.addEventListener('click', function() {
      var btn = this;
      var value = btn.dataset.copyValue;
      if (!value) return;
      var restore = btn.textContent;

      function done(label) {
        btn.textContent = label;
        setTimeout(function() {
          btn.textContent = restore;
        }, 1500);
      }

      if (navigator.clipboard && navigator.clipboard.writeText) {
        navigator.clipboard.writeText(value).then(function() {
          done('Kopieret');
        }).catch(function() {
          done('Kopiér manuelt');
        });
      } else {
        done('Kopiér manuelt');
      }
    });
  })();
  </script>
</AdminLayout>
